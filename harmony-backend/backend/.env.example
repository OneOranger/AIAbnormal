# ============== LLM Provider (任填一个,都不填走 mock) ==============
# 优先级: OPENAI > QWEN > DEEPSEEK > MOCK
#OPENAI_API_KEY=your_openai_api_key_here
#OPENAI_MODEL=gpt-4o-mini
#OPENAI_BASE_URL=https://api.gptsapi.net/v1
#OPENAI_ENABLED=true

# 通义千问 (DashScope)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen-turbo
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 强制使用某个 Provider (覆盖优先级): openai | qwen | deepseek | mock
LLM_PROVIDER=

# ============== 服务配置 ==============
APP_NAME=ai-payment-anomaly-backend
APP_ENV=dev
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# CORS — 前端地址(开发时一般是 5173)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# ============== 数据 ==============
DATA_DIR=./data
STORAGE_DIR=./storage
MOCK_ORDER_COUNT=1200
MOCK_RECON_COUNT=480
# 客户演示=true 自动生成订单/对账/反馈 mock 数据；真实流程测试=false,改用 /ingest 或 data/examples JSONL 导入
MOCK_DATA_ENABLED=true
# 规则/模型/Agent/策略属于系统配置,通常保持 true；如要完全空环境可设为 false
SEED_DEFAULT_CONFIG=true
RANDOM_SEED=20260421

# ============== ML ==============
ML_AUTO_TRAIN_ON_START=false
ML_RETRAIN_CRON=0 3 * * *

# ============== Agent 推理 ==============
AGENT_DEFAULT_TEMPERATURE=0.3
AGENT_MAX_TOKENS=2048
AGENT_TIMEOUT_SECONDS=60
AGENT_TRIGGER_SCORE=70
